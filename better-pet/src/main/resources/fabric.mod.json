{
  "schemaVersion": 1,
  "id": "better_pet",
  "version": "${version}",
  "name": "Better Pet",
  "description": "Lets tamed cats, wolves and parrots roam near a chosen home position instead of always following their owner.",
  "authors": [
    "Haruko386 Game Studio"
  ],
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main": [
      "studio.haruko.betterpet.BetterPet"
    ],
    "client": [
      "studio.haruko.betterpet.client.BetterPetClient"
    ]
  },
  "mixins": [
    "better-pet.mixins.json",
    {
      "config": "better-pet.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.18.4",
    "minecraft": "=1.21.11",
    "java": ">=21",
    "fabric-api": ">=0.141.4"
  }
}
